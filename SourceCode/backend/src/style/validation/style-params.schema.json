{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://sldagent.dev/schemas/style-params.json",
  "title": "StyleParams",
  "description": "受 JSON Schema 约束的 LLM 样式参数输出，将由 StyleBuilder 映射为 GeoStyler Style。",
  "type": "object",
  "required": ["style_name", "geometry_type", "style_type"],
  "additionalProperties": false,
  "properties": {
    "style_name": {
      "type": "string",
      "minLength": 1,
      "description": "样式名称"
    },
    "geometry_type": {
      "type": "string",
      "enum": ["point", "line", "polygon", "raster"],
      "description": "目标几何类型"
    },
    "style_type": {
      "type": "string",
      "enum": ["simple", "categorized", "classified", "text", "raster"],
      "description": "样式类型"
    },
    "field_name": {
      "type": "string",
      "minLength": 1,
      "description": "属性驱动样式时使用的字段名"
    },

    "fill_color": { "type": "string", "description": "填充颜色（CSS 颜色值）" },
    "fill_opacity": { "type": "number", "minimum": 0, "maximum": 1, "description": "填充不透明度" },
    "stroke_color": { "type": "string", "description": "描边/线条颜色" },
    "stroke_width": { "type": "number", "minimum": 0, "description": "描边/线条宽度" },
    "stroke_opacity": { "type": "number", "minimum": 0, "maximum": 1, "description": "描边不透明度" },
    "stroke_dasharray": { "type": "string", "description": "虚线模式，如 '5 2'" },
    "stroke_linecap": {
      "type": "string",
      "enum": ["butt", "round", "square"],
      "description": "线端帽样式"
    },
    "stroke_linejoin": {
      "type": "string",
      "enum": ["miter", "round", "bevel"],
      "description": "线连接样式"
    },
    "opacity": { "type": "number", "minimum": 0, "maximum": 1, "description": "整体不透明度" },

    "well_known_name": {
      "type": "string",
      "enum": ["circle", "square", "triangle", "star", "cross", "x"],
      "description": "WellKnownName 标记图形"
    },
    "size": { "type": "number", "minimum": 0, "description": "标记大小/字体大小" },
    "rotation": { "type": "number", "description": "标记旋转角度" },

    "line_offset": { "type": "number", "description": "线偏移" },

    "categories": {
      "type": "array",
      "minItems": 1,
      "description": "分类样式定义列表",
      "items": { "$ref": "#/definitions/CategoryDef" }
    },
    "classes": { "type": "integer", "minimum": 2, "description": "分级数量" },
    "classification_method": {
      "type": "string",
      "enum": ["equalInterval", "quantile", "naturalBreaks"],
      "description": "分级方法"
    },
    "color_ramp": {
      "type": "array",
      "minItems": 2,
      "items": { "type": "string" },
      "description": "自定义颜色 ramp"
    },
    "color_scheme": {
      "type": "string",
      "description": "预定义色带名，如 'YlOrRd'"
    },

    "label": { "type": "string", "description": "文本标注字段名或常量" },
    "font_family": { "type": "string", "description": "字体族" },
    "font_size": { "type": "number", "minimum": 0, "description": "字体大小" },
    "font_weight": {
      "type": "string",
      "enum": ["normal", "bold"],
      "description": "字重"
    },
    "font_style": {
      "type": "string",
      "enum": ["normal", "italic", "oblique"],
      "description": "字体样式"
    },
    "halo_color": { "type": "string", "description": "光晕颜色" },
    "halo_radius": { "type": "number", "minimum": 0, "description": "光晕半径" },
    "placement": {
      "type": "string",
      "enum": ["point", "line"],
      "description": "标注位置"
    },
    "offset": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": { "type": "number" },
      "description": "标注偏移 [x, y]"
    },

    "rules": {
      "type": "array",
      "description": "高级规则列表",
      "items": { "$ref": "#/definitions/RuleParams" }
    },
    "min_scale": { "type": "number", "minimum": 0, "description": "最小比例尺分母" },
    "max_scale": { "type": "number", "minimum": 0, "description": "最大比例尺分母" }
  },

  "definitions": {
    "CategoryDef": {
      "type": "object",
      "required": ["value"],
      "additionalProperties": false,
      "properties": {
        "value": {
          "anyOf": [
            { "type": "string" },
            { "type": "number" },
            { "type": "boolean" }
          ],
          "description": "分类值"
        },
        "label": { "type": "string", "description": "分类显示标签" },
        "fill_color": { "type": "string" },
        "stroke_color": { "type": "string" },
        "stroke_width": { "type": "number", "minimum": 0 }
      }
    },
    "RuleParams": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "filter": { "$ref": "#/definitions/Filter" },
        "min_scale": { "type": "number", "minimum": 0 },
        "max_scale": { "type": "number", "minimum": 0 },
        "symbolizers": {
          "type": "array",
          "items": { "$ref": "#/definitions/SymbolizerParams" }
        }
      }
    },
    "SymbolizerParams": {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": true,
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["Mark", "Line", "Fill", "Text", "Raster"]
        }
      }
    },
    "Filter": {
      "type": "array",
      "description": "GeoStyler Filter 表达式。为降低 LLM 出错概率，Spike 阶段保持宽松定义。",
      "items": true
    }
  }
}
