{
  "name": "@sldagent/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./messages": {
      "types": "./dist/messages.d.ts",
      "default": "./dist/messages.js"
    },
    "./patch": {
      "types": "./dist/patch.d.ts",
      "default": "./dist/patch.js"
    },
    "./filter": {
      "types": "./dist/filter/index.d.ts",
      "default": "./dist/filter/index.js"
    },
    "./filter/*": {
      "types": "./dist/filter/*.d.ts",
      "default": "./dist/filter/*.js"
    }
  },
  "scripts": {
    "build": "tsc"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
