{
  "name": "@sldagent/electron",
  "version": "1.0.0",
  "description": "SLDAgent Electron shell - main process, preload, and window management",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -b",
    "dev": "electron ."
  },
  "dependencies": {
    "@sldagent/core": "1.0.0",
    "ajv": "^8.16.0",
    "chalk": "^5.3.0",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^24.13.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.11.0"
  },
  "build": {
    "appId": "com.sldagent.app",
    "productName": "SLDAgent",
    "directories": {
      "output": "../../dist"
    },
    "asar": false,
    "files": [
      "dist/**/*",
      {
        "from": "../backend/dist",
        "to": "backend/dist",
        "filter": ["**/*"]
      },
      {
        "from": "../frontend/dist",
        "to": "frontend/dist",
        "filter": ["**/*"]
      }
    ],
    "extraResources": [
      {
        "from": "../data",
        "to": "data"
      },
      {
        "from": "../config",
        "to": "config"
      }
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
