{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "references": [
    { "path": "./SourceCode/core" },
    { "path": "./SourceCode/frontend" },
    { "path": "./SourceCode/backend" },
    { "path": "./SourceCode/electron" }
  ],
  "files": []
}
